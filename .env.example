# Raum AI News Bot Config Example
# Copy this file to .env and fill in your secrets

# Telegram Bot settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_username_or_numeric_id

# Groq LLM settings
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Database settings
# Leave empty to use local SQLite (news.db) during development.
# On Railway, provisioning Postgres will automatically set this value.
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Bot scheduling settings
POLL_INTERVAL_HOURS=3.0
